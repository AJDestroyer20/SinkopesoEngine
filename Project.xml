<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- ═══════════════════════════════════════════════════════════════════════
	     SinkopesoEngine — Project.xml
	     Modernized from Kade Engine / Revolution Engine.
	
	     Pinned library versions:
	       flixel              5.6.1
	       flixel-addons       3.2.2
	       flixel-tools        1.5.1
	       lime                8.1.2
	       openfl              9.3.3
	       hxvlc               2.0.1   (replaces extension-webm)
	       hxdiscord_rpc       1.2.4   (replaces discord_rpc)
	       hscript-iris        1.1.3   (replaces hscript; install via git)
	       linc_luajit         git     (superpowers04 fork)
	       flxanimate          git     (Dot-Stuff @ 768740a)
	       funkin.vis          git     (FunkinCrew/funkVis)
	       grig.audio          0.0.5
	       tjson               1.4.0
	       hxcpp-debug-server  1.2.4
	       polymod             latest
	       actuate             latest
	
	     Git installs:
	       haxelib git hscript-iris  https://github.com/crowplexus/hscript-iris
	       haxelib git linc_luajit   https://github.com/superpowers04/linc_luajit.git
	       haxelib git flxanimate    https://github.com/Dot-Stuff/flxanimate 768740a56b26aa0c072720e0d1236b94afe68e3e
	       haxelib git funkin.vis    https://github.com/FunkinCrew/funkVis
	     ═══════════════════════════════════════════════════════════════════════ -->

	<!-- _________________________ Application Settings _________________________ -->

	<app title="SinkopesoEngine"
	     file="SinkopesoEngine"
	     packageName="com.ajdestroyer20.indosilverclub"
	     package="com.ajdestroyer20.indosilverclub"
	     main="Main"
	     version="1.0.0"
	     company="AJDestroyer20" />

	<app preloader="flixel.system.FlxPreloader" />

	<set name="SWF_VERSION" value="11.8" />

	<!-- ____________________________ Build dirs ________________________________ -->

	<set name="BUILD_DIR" value="export/debug"   if="debug"    />
	<set name="BUILD_DIR" value="export/release" unless="debug"/>
	<set name="BUILD_DIR" value="export/32bit"   if="32bit"    />

	<!-- ____________________________ Window Settings ___________________________ -->

	<window width="1280" height="720" fps="120" background="#000000" hardware="true" vsync="false" />
	<window if="html5"   resizable="true" />
	<window unless="web" orientation="landscape" fullscreen="false" resizable="true" vsync="false" />
	<window if="mobile"  orientation="landscape" fullscreen="true"  width="0" height="0" resizable="false" />
	<window if="switch"  orientation="landscape" fullscreen="true"  width="0" height="0" resizable="true" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<classpath name="source" />
	<classpath name=".haxelib/hscript-iris/git" />
	<classpath name=".haxelib/linc_luajit/git/" />

	<assets path="assets/preload" rename="assets" exclude="*.ogg,*.flac,*.m4a" if="web"     />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" unless="web" />

	<define name="PRELOAD_ALL"    unless="web"        />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<section if="PRELOAD_ALL">
		<library name="songs"    preload="true" />
		<library name="shared"   preload="true" />
		<library name="tutorial" preload="true" />
		<library name="week1"    preload="true" />
		<library name="week2"    preload="true" />
		<library name="week3"    preload="true" />
		<library name="week4"    preload="true" />
		<library name="week5"    preload="true" />
		<library name="week6"    preload="true" />
		<library name="sm"       preload="true" />
	</section>

	<section if="NO_PRELOAD_ALL">
		<library name="songs"    preload="false" />
		<library name="shared"   preload="false" />
		<library name="tutorial" preload="false" />
		<library name="week1"    preload="false" />
		<library name="week2"    preload="false" />
		<library name="week3"    preload="false" />
		<library name="week4"    preload="false" />
		<library name="week5"    preload="false" />
		<library name="week6"    preload="false" />
		<library name="sm"       preload="false" />
	</section>

	<assets path="assets/songs"    library="songs"    exclude="*.ogg" if="web"     />
	<assets path="assets/songs"    library="songs"    exclude="*.mp3" unless="web" />
	<assets path="assets/shared"   library="shared"   exclude="*.ogg" if="web"     />
	<assets path="assets/shared"   library="shared"   exclude="*.mp3" unless="web" />
	<assets path="assets/tutorial" library="tutorial" exclude="*.ogg" if="web"     />
	<assets path="assets/tutorial" library="tutorial" exclude="*.mp3" unless="web" />
	<assets path="assets/week1"    library="week1"    exclude="*.ogg" if="web"     />
	<assets path="assets/week1"    library="week1"    exclude="*.mp3" unless="web" />
	<assets path="assets/week2"    library="week2"    exclude="*.ogg" if="web"     />
	<assets path="assets/week2"    library="week2"    exclude="*.mp3" unless="web" />
	<assets path="assets/week3"    library="week3"    exclude="*.ogg" if="web"     />
	<assets path="assets/week3"    library="week3"    exclude="*.mp3" unless="web" />
	<assets path="assets/week4"    library="week4"    exclude="*.ogg" if="web"     />
	<assets path="assets/week4"    library="week4"    exclude="*.mp3" unless="web" />
	<assets path="assets/week5"    library="week5"    exclude="*.ogg" if="web"     />
	<assets path="assets/week5"    library="week5"    exclude="*.mp3" unless="web" />
	<assets path="assets/week6"    library="week6"    exclude="*.ogg" if="web"     />
	<assets path="assets/week6"    library="week6"    exclude="*.mp3" unless="web" />
	<assets path="assets/sm"       library="sm"       exclude="*.ogg" if="web"     />
	<assets path="assets/sm"       library="sm"       exclude="*.mp3" unless="web" />

	<assets path="example_mods"    rename="mods"              embed="false" />
	<assets path="art/readme.txt"  rename="do NOT readme.txt"              />
	<assets path="assets/fonts"    embed="true"                            />

	<!-- Sinkopeso: runtime script and shader paths -->
	<assets path="assets/scripts"  rename="scripts"  embed="false"                          />
	<assets path="assets/shaders"  rename="shaders"  embed="false" if="FEATURE_ADVANCED_GFX"/>

	<!-- _______________________________ Libraries ______________________________ -->

	<!-- ── HaxeFlixel stack ─────────────────────────────────────────────────── -->
	<haxelib name="flixel"        version="5.6.1" />
	<haxelib name="flixel-addons" version="3.2.2" />
	<haxelib name="flixel-ui"                     />
	<haxelib name="flixel-tools"  version="1.5.1" />
	<haxedev set="webgl" />

	<!-- ── Audio / vis ──────────────────────────────────────────────────────── -->
	<haxelib name="actuate"                       />
	<haxelib name="grig.audio"    version="0.0.5" unless="web" />
	<haxelib name="funkin.vis"                    unless="web" />

	<!-- ── Video: hxvlc replaces extension-webm ─────────────────────────────── -->
	<!--
	     REMOVED: extension-webm (dead, Windows-only, broken on Haxe 4+)
	     ADDED:   hxvlc 2.0.1    (cross-platform, libvlc backend)
	     Platforms: Windows, Mac, Linux, Android, iOS
	     NOT:       html5, Switch
	-->
	<haxelib name="hxvlc" version="2.0.1" if="FEATURE_VIDEO" />

	<!-- ── Sprite animation ─────────────────────────────────────────────────── -->
	<!-- haxelib git flxanimate https://github.com/Dot-Stuff/flxanimate 768740a56b26aa0c072720e0d1236b94afe68e3e -->
	<haxelib name="flxanimate" />

	<!-- ── Discord RPC: hxdiscord_rpc replaces discord_rpc ──────────────────── -->
	<haxelib name="hxdiscord_rpc" version="1.2.4" unless="web" />

	<!-- ── JSON ─────────────────────────────────────────────────────────────── -->
	<haxelib name="tjson" version="1.4.0" />

	<!-- ── HScript: hscript-iris replaces bare hscript ──────────────────────── -->
	<!--
	     REMOVED: hscript (bare, no import support)
	     REMOVED: hxcrow  (does not exist)
	     ADDED:   hscript-iris 1.1.3 (crowplexus, Psych-compatible)
	     Install: haxelib git hscript-iris https://github.com/crowplexus/hscript-iris
	-->
	<haxelib name="hscript-iris" if="HSCRIPT_ALLOWED" />

	<!-- ── Lua: superpowers04 linc_luajit, removes hxvm-luajit ──────────────── -->
	<!--
	     Install: haxelib git linc_luajit https://github.com/superpowers04/linc_luajit.git
	     REMOVED: hxvm-luajit (conflicts with linc_luajit)
	-->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB" />
	<haxelib name="linc_luajit" if="LUA_ALLOWED" />

	<!-- ── Mod loader ───────────────────────────────────────────────────────── -->
	<haxelib name="polymod" 			    unless="web" 			/> 
	
	<!-- ── Switch audio ─────────────────────────────────────────────────────── -->
	<haxelib name="faxe" if="switch" />

	<!-- ── Debug server ─────────────────────────────────────────────────────── -->
	<haxelib name="hxcpp-debug-server" version="1.2.4" if="debug" />

	<!-- _______________________________ Haxedefines ___________________________ -->

	<!-- ── Flixel ───────────────────────────────────────────────────────────── -->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG"        unless="debug"  />
	<haxedef name="HXCPP_GC_BIG_BLOCKS"                 />
	<haxedef name="NAPE_RELEASE_BUILD"  unless="debug"  />

	<!-- ── Feature flags ────────────────────────────────────────────────────── -->
	<haxedef name="FEATURE_DISCORD"         unless="web"           />
	<haxedef name="FEATURE_FILESYSTEM"      unless="web"           />
	<haxedef name="FEATURE_LUAMODCHART"     unless="web"           />
	<haxedef name="LUA_ALLOWED"             unless="web"           />

	<!-- FEATURE_VIDEO replaces FEATURE_WEBM; works on desktop + mobile (not web/switch) -->
	<haxedef name="FEATURE_VIDEO"           if="(windows || linux || mac || android || ios)" />

	<haxedef name="FEATURE_STEPMANIA"       unless="web"           />
	<haxedef name="FEATURE_MULTITHREADING"  unless="web"           />
	<haxedef name="FEATURE_MODCORE"         unless="web"           />

	<!-- Scripting -->
	<haxedef name="HSCRIPT_ALLOWED"         unless="web"           />

	<!-- Sinkopeso additions -->
	<haxedef name="FEATURE_ADVANCED_GFX"    unless="mobile"        />
	<haxedef name="FEATURE_PLUGINS"         unless="web"           />
	<haxedef name="FEATURE_EDITOR"          if="debug"             />
	<haxedef name="FEATURE_HOT_RELOAD"      if="debug"             />
	<haxedef name="FEATURE_MOD_META"                               />

	<!-- __ Compile flags _______________________________________________________ -->

	<haxeflag name="-D no-traces" unless="debug"  />
	<haxeflag name="--dce full"  if="release"    />

	<!-- _________________________________ Icons ________________________________ -->

	<icon path="art/icon8.png"   size="8"   />
	<icon path="art/icon16.png"  size="16"  />
	<icon path="art/icon32.png"  size="32"  />
	<icon path="art/icon64.png"  size="64"  />
	<icon path="art/icon128.png" size="128" />
	<icon path="art/icon256.png" size="256" />
	<icon path="art/icon512.png" size="512" />
	<icon path="art/iconOG.png"             />

</project>
